   "source": [
    "import requests, json\n",
    "\n",
    "nct_id = 'NCT06728059'\n",
    "r = requests.get(f'https://clinicaltrials.gov/api/v2/studies/{nct_id}')\n",
    "data = r.json()\n",
    "\n",
    "print('Has results:', data.get('hasResults'))\n",
    "print(json.dumps(data.get('resultsSection', {}), indent=2))"
   ]
  }
